{
  "name": "turkish-chromium",
  "version": "1.0.0",
  "description": "The Turkish Chromium - A Chromium-based web browser",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "keywords": ["browser", "chromium", "electron"],
  "author": "Turkish Chromium Team",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.turkishchromium.browser",
    "productName": "The Turkish Chromium",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "public/**/*",
      "database/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/assets/logo.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/assets/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/assets/logo.png"
    }
  }
}
